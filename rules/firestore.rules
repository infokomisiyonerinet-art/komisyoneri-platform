rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────
    // NOTE: role checks read the caller's OWN users/{uid} document rather
    // than a Firebase Auth custom claim (request.auth.token.role). This app
    // has no Cloud Function that ever calls setCustomUserClaims(), so a
    // token-claim-based check would be permanently undefined for every user,
    // including real admins. Roles are assigned by writing users/{uid}.role
    // (see index.html's _fsPendingApprove()), so that's the source of truth
    // these rules must check against.
    function isAuth() {
      return request.auth != null;
    }
    function callerDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function getRole() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? callerDoc().data.role
        : null;
    }
    function isRole(r) {
      return isAuth() && getRole() != null && getRole().lower() == r.lower();
    }
    function isAdminOrStaff() {
      // Includes 'ceo': the client UI has always treated ceo as
      // admin-equivalent in ~20 places (approve/reject actions, HR admin
      // controls, exec/BI dashboards), but this rule previously didn't —
      // so a ceo account clicking those buttons got a silent write
      // rejection. Aligning the two: a CEO shouldn't have less write
      // capability than regular staff.
      // 'branch_manager', 'hr_manager', 'operations_manager',
      // 'marketing_manager', and 'company_owner' are staff-tier roles
      // (same trust level as 'staff'/'ceo' — no per-branch or
      // per-department write restriction exists for 'staff' either, so
      // these introduce no new permission beyond what that tier already
      // has) — see ROLE_TIERS.STAFF in index.html, which this list must
      // stay in sync with.
      return isAuth() && getRole() != null &&
        getRole().lower() in ['admin', 'super_admin', 'staff', 'ceo', 'branch_manager', 'hr_manager', 'operations_manager', 'marketing_manager', 'company_owner', 'director', 'accountant', 'chief_broker', 'customer_support_manager', 'it_manager', 'legal_adviser'];
    }
    function isInternalTeam() {
      return isAuth() && getRole() != null &&
        getRole().lower() in ['agent', 'staff', 'admin', 'super_admin', 'ceo', 'branch_manager', 'hr_manager', 'operations_manager', 'marketing_manager', 'company_owner', 'director', 'accountant', 'chief_broker', 'customer_support_manager', 'it_manager', 'legal_adviser'];
    }
    // CEO vs Operations Director governance boundary: both are staff-tier
    // (isAdminOrStaff() above still covers their day-to-day access), but a
    // narrow set of collections below (strategy, governance, shares, major
    // contracts, senior-staff actions, loans/asset disposals) are CEO-only
    // or CEO-write/director-read, and the 'director' role additionally gets
    // a narrower users/{uid} update grant than the rest of the staff tier
    // (see that match block below). 'director' is this app's real "Operations
    // Director" role value — see ROLE_TIERS.STAFF in index.html.
    function isCEO() {
      return isRole('ceo');
    }
    function isDirector() {
      return isRole('director');
    }
    function isExecutive() {
      return isCEO() || isDirector();
    }
    // Reads the TARGET user's own role (not the caller's) — used only by the
    // isDirector() carve-out on users/{uid} update, so a director can manage
    // regular staff/agents but not reassign/edit other senior managers.
    function isSeniorManager(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.role.lower() in
           ['ceo', 'company_owner', 'branch_manager', 'hr_manager', 'operations_manager',
            'marketing_manager', 'director', 'accountant', 'chief_broker',
            'customer_support_manager', 'it_manager', 'legal_adviser'];
    }
    // Final Management Org Chart — department is DERIVED from role (this app
    // has exactly one management role per department; see ROLE_DEPARTMENT in
    // index.html, which this must stay in sync with), not a second
    // independently-trusted field. Avoids the drift risk of a stored
    // department field disagreeing with the role that actually grants trust.
    function deptOfRole(r) {
      return r == 'ceo' || r == 'director' ? 'Executive'
        : r == 'accountant' ? 'Finance'
        : r == 'chief_broker' ? 'Brokerage'
        : r == 'marketing_manager' ? 'Marketing'
        : r == 'customer_support_manager' ? 'CustomerSupport'
        : r == 'it_manager' ? 'IT'
        : r == 'hr_manager' ? 'HR'
        : r == 'legal_adviser' ? 'Legal'
        : '';
    }
    function inDept(dept) {
      return isAuth() && getRole() != null && deptOfRole(getRole().lower()) == dept;
    }
    function hasStandardFields() {
      return request.resource.data.keys().hasAll([
        'id','createdAt','updatedAt','createdBy','updatedBy','status','isActive'
      ]);
    }
    // ── EXISTING collections ──────────────────────────

    match /users/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isAdminOrStaff());
      allow create: if isAuth() && request.auth.uid == uid && hasStandardFields();
      // Narrow, additive carve-out for the "Become an Agent" self-service
      // application (see index.html's submitAgentReg()) — the only way a
      // non-admin is allowed to move their own doc's role/status/isActive/
      // isVerified at all. It only ever lands the caller in the *pending*
      // state, never the approved one: isVerified must be exactly false and
      // status exactly 'pending', so an applicant can never self-approve, and
      // an existing staff/admin/super_admin account can't use it to reset
      // itself. Only admins (via _fsPendingApprove()) can ever flip
      // isVerified/status to their approved values. Must be declared inside
      // this match block (not alongside the top-level helpers above) because
      // it reads the {uid} path binding, which only exists in this scope.
      function isSelfAgentApplication() {
        return isAuth() && request.auth.uid == uid
          && !(resource.data.get('role', 'client').lower() in ['admin','super_admin','staff'])
          && request.resource.data.role == 'agent'
          && request.resource.data.status == 'pending'
          && request.resource.data.isActive == true
          && request.resource.data.isVerified == false
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['role','status','isActive','isVerified','displayName','phone','email',
                       'nationalId','address','district','zone','experience','transport',
                       'languages','agentAppliedAt','updatedAt','updatedBy']);
      }
      // A non-admin may only ever touch their own doc, and only the handful
      // of fields the profile-edit UI actually writes (see saveEditProfile(),
      // favorites toggle, referral code generation) — never `role`, `status`,
      // `isActive`, `isVerified`, `budgetApprovalLimit`, or any other field
      // that every isAdminOrStaff() check in this entire ruleset (and in the
      // app itself) ultimately derives from. Without this allowlist, any
      // signed-in user could self-escalate by writing role:'admin' to their
      // own document — this is also why budgetApprovalLimit (CEO vs
      // Operations Director governance, see approvals/budgetRequests below)
      // is admin/CEO-settable only and never appears in this list: a
      // director can never raise their own approval limit.
      // isSelfAgentApplication() is the one deliberate, tightly-scoped
      // exception (see its own comment).
      //
      // isDirector() gets a narrower grant than the rest of the staff tier:
      // every other isAdminOrStaff() role keeps blanket update access to any
      // user doc, but a director may not edit another senior manager's doc
      // (isSeniorManager(uid), literal role-list check on the TARGET doc) —
      // they can still edit their own doc and any regular staff/agent/client
      // doc. This is a deliberate, scoped exception to the otherwise-uniform
      // staff-tier trust model documented in
      // tests/rules/test/03-staff-tier-uniform-trust.spec.js.
      allow update: if (isAdminOrStaff() && !isDirector())
                    || (isDirector() && (request.auth.uid == uid || !isSeniorManager(uid)))
                    || isSelfAgentApplication()
                    || (isAuth() && request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['phone','location','preference','photoURL','themePref',
                                     'referralCode','favorites','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /properties/{id} {
      allow read:   if true;
      allow create: if isAuth() && hasStandardFields();
      // The owning agent/owner may edit their own listing's content, but
      // never the fields that represent the admin-review decision itself
      // (status, approvedBy, approvedAt, isVerified) or reassign ownership
      // (agentId, ownerId) — matches what the self-edit UI actually sends
      // (see the edit-mode branch of submitProperty()) and closes off a
      // client-side bypass of the "every listing is admin-reviewed" guarantee.
      allow update: if isAdminOrStaff()
                    || ((resource.data.agentId == request.auth.uid || resource.data.ownerId == request.auth.uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['type','category','district','sector','price','bedrooms',
                                     'bathrooms','area','description','title','amenities',
                                     'images','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /leads/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /deals/{id} {
      // P0.1 security closure (adversarial re-audit found this the same
      // day #70 merged): the old create/update rules let ANY authenticated
      // user fabricate a deal naming themselves as its own agentId with an
      // arbitrary agreedPrice, then self-transition it to closed_won —
      // laundering an arbitrary amount into a REAL, Admin-SDK-written
      // commission + invoice via the legitimate onDealClosedWon cascade
      // (that trigger bypasses rules entirely, so it can't be the backstop).
      //
      // Fix has two parts:
      // 1. create requires the caller be an actual party to the deal (its
      //    own agentId or its own clientId) unless they're admin/staff —
      //    covers both convertLeadToDeal()'s agent-initiated creation and
      //    submitOffer()'s buyer-initiated creation (where the agent is a
      //    real third party, not the creator) — and a deal can never be
      //    born already closed_won.
      // 2. update to closed_won — the money-triggering transition — now
      //    requires admin/staff, full stop. A non-staff agent keeps full
      //    update rights on every other stage/field of their own deal, but
      //    can neither reassign agentId away from themselves nor
      //    self-approve the one transition that generates real money.
      //    onDealClosedWon (functions/index.js) independently re-verifies
      //    the actor was genuinely staff as a second, server-side layer.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.pipelineStage != 'closed_won'
                    && (isAdminOrStaff()
                        || request.resource.data.agentId == request.auth.uid
                        || request.resource.data.clientId == request.auth.uid);
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid
                        && request.resource.data.agentId == request.auth.uid
                        && request.resource.data.pipelineStage != 'closed_won');
      allow delete: if false;
    }

    match /commissions/{id} {
      // P0 remediation (Enterprise Readiness Audit): the old `isAuth() &&
      // hasStandardFields()` create rule let ANY authenticated user forge a
      // commission with status:'approved' and an arbitrary agentShare —
      // skipping the approval workflow entirely. Real client creation
      // paths (convertLeadToDeal(), calculatePlotCommission(),
      // createManualCommission() in index.html) all legitimately need to
      // create a commission client-side and must keep working, so create
      // isn't locked to admin/staff — instead it's pinned to status ==
      // 'pending', which has zero monetary effect on its own. The only
      // rule that can ever move a commission to 'approved' or 'paid' is
      // `update`, already admin/staff-only below, so this closes the
      // forge-an-approved-commission path without breaking any existing
      // workflow. The Cloud Function that creates real deal commissions
      // (onDealClosedWon) writes via the Admin SDK, which bypasses rules
      // entirely, so it needs no allowance here either.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.status == 'pending';
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /subscriptions/{id} {
      // Doc id is always the agent's own uid (see subscribeToPremium() /
      // dailySubscriptionSync in functions/index.js), so `id ==
      // request.auth.uid` and the agentId field check are redundant with
      // each other on purpose — cheap defense in depth, not load-bearing
      // on its own. Unlike payout_requests, this doesn't restrict WHICH
      // fields an agent can change on their own doc (e.g. to a narrow
      // status transition): a subscription is entirely self-managed
      // bookkeeping with no payment gateway behind it, so the worst case
      // of an agent tampering with their own currentPeriodEnd is "they
      // keep believing they're subscribed a bit longer," not a real
      // financial loss — nothing here moves money. The Cloud Function
      // that actually bills renewals writes via the Admin SDK, which
      // bypasses these rules entirely, so it needs no allowance here.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.agentId == request.auth.uid
                    && id == request.auth.uid;
      allow update: if isAdminOrStaff()
                    || (isAuth() && id == request.auth.uid
                        && request.resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /payout_requests/{id} {
      // A payout request is a snapshot of specific commission doc IDs +
      // their summed agentShare at request time (see submitPayoutRequest()
      // in index.html). Approving one no longer batch-updates commissions
      // directly from the client — see P0.1 note below.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      // Tightened beyond the `leaves` collection's equivalent create rule
      // (which doesn't check the self-ownership field): this collection
      // moves money, so a client can only ever create a payout request
      // for themselves, not on another agent's behalf. Also pinned to
      // status == 'pending' so a request can never be self-created
      // already 'approved'.
      //
      // P0.1 security closure: the adversarial re-audit of #70 found that
      // serverVerified/verifiedAmount/verifiedAt — the fields the whole
      // approval gate depends on — were writable by the client, since the
      // create rule never constrained them. A client could set
      // serverVerified:true on their own forged request, and
      // approvePayoutRequest() only ever checked that flag, never status.
      // Now: creation must set all three to their explicit unverified
      // defaults, and no update path (admin included) may ever change
      // them — only the onPayoutRequestCreated Cloud Function (Admin SDK,
      // bypasses these rules) can ever set serverVerified:true.
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.agentId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.serverVerified == false
                    && request.resource.data.verifiedAmount == 0
                    && request.resource.data.verifiedAt == null;
      // The requesting agent may only cancel their own still-pending
      // request (not approve it, not change the amount) — a plain
      // document update, so unlike list reads this can safely inspect
      // resource.data.status directly. Admin/staff may reject freely, but
      // may only transition INTO 'approved' from a genuinely 'pending' +
      // already-server-verified request — never a request the trigger
      // hasn't cleared yet, structurally closing the exact forgery this
      // section's comment above describes. The actual commission-paid
      // batch write happens in onPayoutRequestApproved (functions/
      // index.js), which independently re-verifies everything a second
      // time before moving anything, since server-verified state can go
      // stale between verification and approval (e.g. a commission paid
      // out via a different, concurrent request).
      allow update: if (request.resource.data.serverVerified == resource.data.serverVerified
                        && request.resource.data.verifiedAmount == resource.data.verifiedAmount
                        && request.resource.data.verifiedAt == resource.data.verifiedAt)
                    && ((isAdminOrStaff()
                         && (request.resource.data.status != 'approved'
                             || (resource.data.status == 'pending' && resource.data.serverVerified == true)))
                        || (isAuth() && resource.data.agentId == request.auth.uid
                            && resource.data.status == 'pending'
                            && request.resource.data.status == 'cancelled'));
      allow delete: if false;
    }

    match /documents/{id} {
      // accessRoles (checked at upload, e.g. by submitDocumentUpload() in
      // index.html) lets staff file a document under a client's clientId
      // without it being visible in that client's own portal — a client
      // may only read/update their own document if 'client' is one of the
      // marked accessRoles, and likewise an agent only via 'agent'. Docs
      // with no accessRoles field at all default to visible, matching
      // this rule's own pre-accessRoles behavior.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && 'client' in resource.data.get('accessRoles', ['client']))
                    || (isAuth() && resource.data.agentId  == request.auth.uid
                        && 'agent' in resource.data.get('accessRoles', ['agent']));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && 'client' in resource.data.get('accessRoles', ['client']))
                    || (isAuth() && resource.data.agentId  == request.auth.uid
                        && 'agent' in resource.data.get('accessRoles', ['agent']));
      allow delete: if false;
    }

    match /offers/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid));
      allow delete: if false;
    }

    match /viewings/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow create: if isAuth() && hasStandardFields()
                    && (request.resource.data.clientId == request.auth.uid
                        || request.resource.data.agentId == request.auth.uid
                        || isAdminOrStaff());
      allow update: if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow delete: if false;
    }

    match /services/{id} {
      // assignedToId is the assigned partner's real account uid (see
      // index.html's assignServicePartner()) — assignedTo is a display
      // name string only, never an auth uid, so it must not be used here.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.requestedBy == request.auth.uid
                        || resource.data.assignedToId == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedToId == request.auth.uid);
      allow delete: if false;
    }

    match /partners/{id} {
      allow read:   if true;
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    match /invoices/{id} {
      // P0 remediation: same shape of gap as commissions above — any
      // authenticated user could previously create an invoice already
      // marked 'paid' or 'refunded', polluting revenue records. Every
      // legitimate client creation path (manual Accounting invoices via
      // submitInvoice(), referral/partner payout invoices) only ever
      // writes 'draft' or 'sent'; 'paid'/'refunded' only ever happen via
      // the admin/staff-only `update` rule below. Cloud Functions
      // (deal-close and subscription-renewal invoices) use the Admin SDK
      // and bypass rules entirely.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.billedTo == request.auth.uid)
                    || (isAuth() && resource.data.clientId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.status in ['draft', 'sent'];
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /expenses/{id} {
      allow read:   if isAdminOrStaff();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /tasks/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow delete: if false;
    }

    match /attendance/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    match /leaves/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /payroll/{id} {
      // Final Management Org Chart: HR Manager's deniedActions includes
      // "change_salaries_unapproved" — HR may still read payroll like every
      // other staff-tier role, but can no longer write it directly; a salary
      // change must go through /approvals instead (see index.html's salary-
      // change flow). This is a deliberate, scoped exception to the
      // otherwise-uniform staff-tier trust model documented in
      // tests/rules/test/03-staff-tier-uniform-trust.spec.js (payroll is no
      // longer part of that uniform set — expenses/assets still are).
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAdminOrStaff() && !inDept('HR') && hasStandardFields();
      allow update: if isAdminOrStaff() && !inDept('HR');
      allow delete: if false;
    }

    match /reviews/{id} {
      // Fully public — this collection is exclusively partner ratings now
      // (staff performance reviews live in staff_reviews, see below). No
      // field-dependent branching here on purpose: Firestore cannot prove
      // a list/query read is safe when a rule branches on a field that
      // isn't part of the query filter, which is exactly what previously
      // let an unrelated user list another employee's private reviews
      // (verified against the rules-enabled emulator) when this collection
      // still held both kinds of data. Fixed by migrating the old staff
      // review docs out (scripts/migrate-staff-reviews.js — MUST run
      // before deploying this rule) rather than trying to keep any
      // conditional branching here.
      allow read:   if true;
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.get('subjectType', 'partner') != 'staff';
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /staff_reviews/{id} {
      // Kept as its own collection rather than reusing `reviews` (which
      // mixes in publicly-readable partner ratings): a rule that branches
      // on a field not present in every document of a collection cannot be
      // proven safe by Firestore for list/query reads, and empirically
      // (verified against the rules-enabled emulator) that ambiguity lets
      // an unrelated authenticated user list another employee's private
      // reviews. staffId is always present here and always matches the
      // query filter loadStaffReviewHistory() actually issues, so this
      // stays simple and provably safe for both get and list.
      allow read:   if isAdminOrStaff() || (isAuth() && resource.data.staffId == request.auth.uid);
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if false;
      allow delete: if false;
    }

    match /assets/{id} {
      // Internal equipment registry — admin/staff only, no public or
      // self-service read (unlike staff_reviews, no employee-facing "my
      // assets" view exists yet, so there's no need for the staffId-style
      // list-safe carve-out).
      allow read:   if isAdminOrStaff();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /branches/{id} {
      allow read:   if isAuth();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /departments/{id} {
      allow read:   if isAuth();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /job_postings/{id} {
      // Public read — the Careers page lists open postings to signed-out
      // visitors, same as property listings.
      allow read:   if true;
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /job_applications/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.applicantId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /referrals/{id} {
      allow read:   if isAuth() && (resource.data.referrerId == request.auth.uid || isAdminOrStaff());
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    // ── INVESTOR PORTAL ────────────────────────────────
    match /investments/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.investorId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.investorId == request.auth.uid;
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.investorId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /notifications/{id} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /messages/{id} {
      // Two shapes share this collection: 1:1 client<->agent messages
      // (participants array) and internal team-channel posts (channel
      // field, no participants) — added for the Office Management team
      // channel feature rather than creating a duplicate collection.
      allow read:   if isAuth() && (
                      isAdminOrStaff()
                      || ('participants' in resource.data && request.auth.uid in resource.data.participants)
                      || ('channel' in resource.data && isInternalTeam())
                    );
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.fromId == request.auth.uid
                    && (
                      ('participants' in request.resource.data && request.auth.uid in request.resource.data.participants)
                      || ('channel' in request.resource.data && isInternalTeam())
                    );
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.toId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['read','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /auditlogs/{id} {
      // Immutable — no updates or deletes ever
      allow read:   if isAdminOrStaff();
      allow create: if isAuth() && hasStandardFields();
      allow update: if false;
      allow delete: if false;
    }

    // ── SITE DEVELOPMENT MODULE ───────────────────────

    match /sites/{siteId} {
      allow read:   if true;
      allow create: if isAuth()
                    && (isRole('agent') || isRole('developer') || isAdminOrStaff())
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && isRole('agent')
                        && resource.data.managingAgentId == request.auth.uid)
                    || (isAuth() && isRole('developer')
                        && resource.data.developerId == request.auth.uid);
      allow delete: if false;
    }

    match /plots/{plotId} {
      allow read:   if true;
      allow create: if isAuth()
                    && (isRole('agent') || isAdminOrStaff())
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth()
                        && get(/databases/$(database)/documents/sites/$(resource.data.siteId))
                           .data.managingAgentId == request.auth.uid)
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','clientId','reservedAt','reservedUntil','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /site_enquiries/{enquiryId} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid)
                    || (isAuth() && resource.data.agentId  == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    // ── CEO vs Operations Director governance ─────────
    // See isCEO()/isDirector()/isSeniorManager() above. Two tiers below:
    // CEO-write/staff-read (strategy + major contracts — director can VIEW
    // but never write), and CEO-only with zero director involvement at all
    // (shares, governance docs, registration, loans/asset disposals, senior
    // staff actions) — matching the governance spec's own section 3 example
    // (`allow read, write: if isCEO()`) exactly.

    match /strategyDocuments/{id} {
      allow read:   if isAdminOrStaff();
      allow create: if isCEO() && hasStandardFields();
      allow update: if isCEO();
      allow delete: if false;
    }

    match /majorContracts/{id} {
      // Legal Adviser reviews/annotates contracts (via contractReviews
      // below) but never holds signing authority — deniedActions:
      // ["sign_contracts_on_company_behalf"]. Read access here is already
      // covered by isAdminOrStaff() (Legal is staff-tier); write stays
      // CEO-only, unchanged — this comment just documents why Legal is
      // deliberately NOT added to the write side.
      allow read:   if isAdminOrStaff();
      allow create: if isCEO() && hasStandardFields();
      allow update: if isCEO();
      allow delete: if false;
    }

    match /shareStructure/{id} {
      allow read, write: if isCEO();
    }

    match /governanceDocuments/{id} {
      allow read, write: if isCEO();
    }

    match /companyRegistration/{id} {
      allow read, write: if isCEO();
    }

    match /loansAndAssetDisposals/{id} {
      allow read, write: if isCEO();
    }

    match /seniorStaffActions/{id} {
      allow read, write: if isCEO();
    }

    // Director's normal day-to-day operating scope — full access, no CEO
    // gate. Distinct from the general isAdminOrStaff() tier: scoped to just
    // CEO + Director per the governance spec, not every staff-tier role.
    match /dailyOperations/{id} {
      allow read:   if isCEO() || isDirector();
      allow create: if (isCEO() || isDirector()) && hasStandardFields();
      allow update: if isCEO() || isDirector();
      allow delete: if false;
    }

    match /reports/{id} {
      // Final Management Org Chart's structured reporting system extends
      // this collection (create isn't duplicated as a second collection) —
      // it started as a CEO/Director-only "our own internal notes" shape
      // (PR before this one) and is broadened here to a real submittedBy/
      // recipients-scoped model any staff-tier role can use: every one of
      // the 9 governance roles must be able to submit reports up their own
      // reportsTo chain, but a report's whole point is routed visibility,
      // not company-wide — so read is scoped to the actual audience
      // (submitter, a listed recipient, or an executive), not a blanket
      // isAdminOrStaff() read. Old CEO/Director-authored docs (no
      // submittedBy/recipients fields) remain readable via the
      // isCEO()||isDirector() branch exactly as before.
      allow read:   if isAdminOrStaff()
                    && (isCEO() || isDirector()
                        || resource.data.get('submittedBy', '') == request.auth.uid
                        || request.auth.uid in resource.data.get('recipients', []));
      allow create: if isAdminOrStaff() && hasStandardFields()
                    && request.resource.data.get('submittedBy', request.auth.uid) == request.auth.uid;
      allow update: if isCEO() || isDirector()
                    || (isAuth() && resource.data.get('submittedBy', '') == request.auth.uid);
      allow delete: if false;
    }

    match /suggestions/{id} {
      allow read:   if isCEO() || isDirector();
      allow create: if (isCEO() || isDirector()) && hasStandardFields();
      allow update: if isCEO() || isDirector();
      allow delete: if false;
    }

    match /approvals/{id} {
      // Director-facing escalation workflow for actions above their budget
      // limit / outside their normal scope — modeled on payout_requests
      // above, NOT the naive "client sets status freely" shape: create pins
      // to safe unverified defaults, no client update (CEO included) may
      // ever touch serverVerified, and the actual approve/reject transition
      // requires serverVerified already true. onApprovalCreated
      // (functions/index.js, Admin SDK) is the only path to
      // serverVerified:true; onApprovalDecided performs the real privileged
      // write to the target collection (via sourceDocRef/type) server-side
      // once CEO approves. Same P0.1 security pattern already proven here.
      allow read:   if isCEO()
                    || (isAuth() && resource.data.requestedBy == request.auth.uid);
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.requestedBy == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.serverVerified == false
                    && request.resource.data.decidedBy == null
                    && request.resource.data.decidedAt == null;
      // Decision authority: isCEO() always (unchanged, covers every approval
      // type that predates the Final Org Chart work), OR — new — the caller's
      // uid is listed in the request's own `routedTo` array. routedTo lets a
      // deniedActions-triggered request (see index.html's requestApproval())
      // be routed to whichever of a role's reportsTo superiors should decide
      // it (e.g. HR's routes to Operations Director OR CEO, either
      // sufficient) without hardcoding CEO as the only possible approver.
      // Purely additive: a doc with no routedTo field falls back to isCEO()
      // exactly as before (resource.data.get('routedTo', []) is empty, so
      // the `in` check can never match), so this doesn't change behavior for
      // any of the existing CEO-only approval types.
      allow update: if request.resource.data.serverVerified == resource.data.serverVerified
                    && (isCEO() || (isAuth() && request.auth.uid in resource.data.get('routedTo', [])))
                    && resource.data.status == 'pending'
                    && resource.data.serverVerified == true
                    && request.resource.data.status in ['approved', 'rejected'];
      allow delete: if false;
    }

    match /budgetRequests/{id} {
      // Director may approve directly within their own budgetApprovalLimit
      // (users/{uid}.budgetApprovalLimit, admin/CEO-settable only — see the
      // users/{uid} update rule above); above the limit, direct update is
      // denied here and the real UI routes the action through /approvals
      // instead. CEO always has full access.
      allow read:   if isAdminOrStaff();
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.requestedBy == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isCEO()
                    || (isDirector()
                        && resource.data.amount <= callerDoc().data.get('budgetApprovalLimit', 0));
      allow delete: if false;
    }

    // ── Final Management Org Chart — HR, Finance, Legal department
    // collections (extends the CEO vs Operations Director governance work
    // above with department-scoped access via inDept(), see deptOfRole()).
    // "recruitment" from the org-chart spec isn't a separate collection —
    // it's the existing job_postings/job_applications collections above,
    // already isAdminOrStaff()-gated (HR already has that access as a
    // staff-tier role); duplicating it here would just be a second,
    // disconnected copy of the same data.

    match /employeeRecords/{id} {
      allow read:   if inDept('HR') || isExecutive();
      allow create: if (inDept('HR') || isExecutive()) && hasStandardFields();
      allow update: if inDept('HR') || isExecutive();
      allow delete: if false;
    }

    match /legalCompliance/{id} {
      allow read:   if inDept('Legal') || isExecutive();
      allow create: if (inDept('Legal') || isExecutive()) && hasStandardFields();
      allow update: if inDept('Legal') || isExecutive();
      allow delete: if false;
    }

    match /contractReviews/{id} {
      // Legal reviews/annotates contracts here — this is NOT signing
      // authority, which stays on majorContracts (CEO-only write, above).
      allow read:   if inDept('Legal') || isExecutive();
      allow create: if (inDept('Legal') || isExecutive()) && hasStandardFields();
      allow update: if inDept('Legal') || isExecutive();
      allow delete: if false;
    }

    match /financeTransactions/{id} {
      // Director of Finance's deniedActions includes "spend_above_limit" —
      // same budgetApprovalLimit field/pattern as budgetRequests above:
      // Finance can create directly only within their own limit; above it,
      // the create is denied here and the real UI routes it through
      // /approvals instead (routedTo resolved from their reportsTo, which
      // for Director of Finance is [CEO, Operations Director]). Executive
      // always bypasses the limit.
      allow read:   if inDept('Finance') || isExecutive();
      allow create: if isExecutive()
                    || (inDept('Finance')
                        && request.resource.data.amount <= callerDoc().data.get('budgetApprovalLimit', 0));
      allow update: if isExecutive();
      allow delete: if false;
    }

    match /bankAccounts/{id} {
      // "open_new_account_unilaterally" — Finance can read account data but
      // can never create or delete an account; that stays Executive-only.
      allow read:   if inDept('Finance') || isExecutive();
      allow create, delete: if isExecutive();
      allow update: if isExecutive();
    }
  }
}
