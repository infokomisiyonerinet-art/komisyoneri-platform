rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────
    // NOTE: role checks read the caller's OWN users/{uid} document rather
    // than a Firebase Auth custom claim (request.auth.token.role). This app
    // has no Cloud Function that ever calls setCustomUserClaims(), so a
    // token-claim-based check would be permanently undefined for every user,
    // including real admins. Roles are assigned by writing users/{uid}.role
    // (see index.html's _fsPendingApprove()), so that's the source of truth
    // these rules must check against.
    function isAuth() {
      return request.auth != null;
    }
    function callerDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function getRole() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? callerDoc().data.role
        : null;
    }
    function isRole(r) {
      return isAuth() && getRole() != null && getRole().lower() == r.lower();
    }
    function isAdminOrStaff() {
      // Includes 'ceo': the client UI has always treated ceo as
      // admin-equivalent in ~20 places (approve/reject actions, HR admin
      // controls, exec/BI dashboards), but this rule previously didn't —
      // so a ceo account clicking those buttons got a silent write
      // rejection. Aligning the two: a CEO shouldn't have less write
      // capability than regular staff.
      return isAuth() && getRole() != null &&
        getRole().lower() in ['admin', 'super_admin', 'staff', 'ceo'];
    }
    function isInternalTeam() {
      return isAuth() && getRole() != null &&
        getRole().lower() in ['agent', 'staff', 'admin', 'super_admin', 'ceo'];
    }
    function hasStandardFields() {
      return request.resource.data.keys().hasAll([
        'id','createdAt','updatedAt','createdBy','updatedBy','status','isActive'
      ]);
    }

    // ── EXISTING collections ──────────────────────────

    match /users/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isAdminOrStaff());
      allow create: if isAuth() && request.auth.uid == uid && hasStandardFields();
      // A non-admin may only ever touch their own doc, and only the handful
      // of fields the profile-edit UI actually writes (see saveEditProfile(),
      // favorites toggle, referral code generation) — never `role`, `status`,
      // `isActive`, `isVerified`, or any other field that every isAdminOrStaff()
      // check in this entire ruleset (and in the app itself) ultimately derives
      // from. Without this allowlist, any signed-in user could self-escalate by
      // writing role:'admin' to their own document.
      allow update: if isAdminOrStaff()
                    || (isAuth() && request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['phone','location','preference','photoURL',
                                     'referralCode','favorites','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /properties/{id} {
      allow read:   if true;
      allow create: if isAuth() && hasStandardFields();
      // The owning agent/owner may edit their own listing's content, but
      // never the fields that represent the admin-review decision itself
      // (status, approvedBy, approvedAt, isVerified) or reassign ownership
      // (agentId, ownerId) — matches what the self-edit UI actually sends
      // (see the edit-mode branch of submitProperty()) and closes off a
      // client-side bypass of the "every listing is admin-reviewed" guarantee.
      allow update: if isAdminOrStaff()
                    || ((resource.data.agentId == request.auth.uid || resource.data.ownerId == request.auth.uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['type','category','district','sector','price','bedrooms',
                                     'bathrooms','area','description','title','amenities',
                                     'images','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /leads/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /deals/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /commissions/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /documents/{id} {
      // accessRoles (checked at upload, e.g. by submitDocumentUpload() in
      // index.html) lets staff file a document under a client's clientId
      // without it being visible in that client's own portal — a client
      // may only read/update their own document if 'client' is one of the
      // marked accessRoles, and likewise an agent only via 'agent'. Docs
      // with no accessRoles field at all default to visible, matching
      // this rule's own pre-accessRoles behavior.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && 'client' in resource.data.get('accessRoles', ['client']))
                    || (isAuth() && resource.data.agentId  == request.auth.uid
                        && 'agent' in resource.data.get('accessRoles', ['agent']));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && 'client' in resource.data.get('accessRoles', ['client']))
                    || (isAuth() && resource.data.agentId  == request.auth.uid
                        && 'agent' in resource.data.get('accessRoles', ['agent']));
      allow delete: if false;
    }

    match /offers/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid));
      allow delete: if false;
    }

    match /viewings/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow create: if isAuth() && hasStandardFields()
                    && (request.resource.data.clientId == request.auth.uid
                        || request.resource.data.agentId == request.auth.uid
                        || isAdminOrStaff());
      allow update: if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      allow delete: if false;
    }

    match /services/{id} {
      // assignedToId is the assigned partner's real account uid (see
      // index.html's assignServicePartner()) — assignedTo is a display
      // name string only, never an auth uid, so it must not be used here.
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.requestedBy == request.auth.uid
                        || resource.data.assignedToId == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedToId == request.auth.uid);
      allow delete: if false;
    }

    match /partners/{id} {
      allow read:   if true;
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    match /invoices/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.billedTo == request.auth.uid)
                    || (isAuth() && resource.data.clientId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /expenses/{id} {
      allow read:   if isAdminOrStaff();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /tasks/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow delete: if false;
    }

    match /attendance/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    match /leaves/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /payroll/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /reviews/{id} {
      // Partner reviews (subjectType != 'staff') are intentionally public;
      // staff performance reviews (subjectType == 'staff') are private to
      // the reviewed employee and admin/staff — never publicly readable.
      allow read:   if resource.data.subjectType == 'staff'
                    ? (isAdminOrStaff() || resource.data.staffId == request.auth.uid)
                    : true;
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /branches/{id} {
      allow read:   if isAuth();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /referrals/{id} {
      allow read:   if isAuth() && (resource.data.referrerId == request.auth.uid || isAdminOrStaff());
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    // ── INVESTOR PORTAL ────────────────────────────────
    match /investments/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.investorId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.investorId == request.auth.uid;
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.investorId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /notifications/{id} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /messages/{id} {
      // Two shapes share this collection: 1:1 client<->agent messages
      // (participants array) and internal team-channel posts (channel
      // field, no participants) — added for the Office Management team
      // channel feature rather than creating a duplicate collection.
      allow read:   if isAuth() && (
                      isAdminOrStaff()
                      || ('participants' in resource.data && request.auth.uid in resource.data.participants)
                      || ('channel' in resource.data && isInternalTeam())
                    );
      allow create: if isAuth() && hasStandardFields()
                    && request.resource.data.fromId == request.auth.uid
                    && (
                      ('participants' in request.resource.data && request.auth.uid in request.resource.data.participants)
                      || ('channel' in request.resource.data && isInternalTeam())
                    );
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.toId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['read','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /auditlogs/{id} {
      // Immutable — no updates or deletes ever
      allow read:   if isAdminOrStaff();
      allow create: if isAuth() && hasStandardFields();
      allow update: if false;
      allow delete: if false;
    }

    // ── SITE DEVELOPMENT MODULE ───────────────────────

    match /sites/{siteId} {
      allow read:   if true;
      allow create: if isAuth()
                    && (isRole('agent') || isRole('developer') || isAdminOrStaff())
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && isRole('agent')
                        && resource.data.managingAgentId == request.auth.uid)
                    || (isAuth() && isRole('developer')
                        && resource.data.developerId == request.auth.uid);
      allow delete: if false;
    }

    match /plots/{plotId} {
      allow read:   if true;
      allow create: if isAuth()
                    && (isRole('agent') || isAdminOrStaff())
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth()
                        && get(/databases/$(database)/documents/sites/$(resource.data.siteId))
                           .data.managingAgentId == request.auth.uid)
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','clientId','reservedAt','reservedUntil','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /site_enquiries/{enquiryId} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid)
                    || (isAuth() && resource.data.agentId  == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }
  }
}
