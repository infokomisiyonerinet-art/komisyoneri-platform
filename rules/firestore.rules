rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isRole(r) {
      return isAuth() && request.auth.token.role == r;
    }
    // ceo added; 'Admin' variant kept for backward compat with legacy tokens
    function isAdminOrStaff() {
      return isAuth() && request.auth.token.role in
        ['admin', 'super_admin', 'staff', 'Admin', 'ceo'];
    }
    function hasStandardFields() {
      return request.resource.data.keys().hasAll([
        'id','createdAt','updatedAt','createdBy','updatedBy','status','isActive'
      ]);
    }
    // Only http/https URLs may be stored as document fields
    function isSafeUrl(url) {
      return url.matches('https?://.*');
    }

    // ── EXISTING collections ──────────────────────────

    match /users/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isAdminOrStaff());
      allow create: if isAuth() && request.auth.uid == uid && hasStandardFields();
      allow update: if isAuth() && (request.auth.uid == uid || isAdminOrStaff());
      allow delete: if false;
    }

    match /properties/{id} {
      allow read:   if true;
      // Only the listing agent, property owner, or admin/staff may update
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId  == request.auth.uid)
                    || (isAuth() && resource.data.ownerId  == request.auth.uid);
      allow delete: if false;
    }

    match /leads/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      // Only agents and above may create leads
      allow create: if isAuth()
                    && request.auth.token.role in
                       ['agent','Agent','staff','admin','Admin','super_admin','ceo']
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /deals/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.clientId == request.auth.uid
                        || resource.data.agentId  == request.auth.uid));
      // Only agents and above may create deals
      allow create: if isAuth()
                    && request.auth.token.role in
                       ['agent','Agent','staff','admin','Admin','super_admin','ceo']
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /commissions/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      // Only admin/staff may create or modify commission records (prevents falsification)
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /documents/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid)
                    || (isAuth() && resource.data.agentId  == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      // Clients may only update signing-related fields on their own docs
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid)
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','signed','signatories','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /offers/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.fromUserId == request.auth.uid)
                    || (isAuth() && resource.data.toUserId   == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      // Only the offer sender, the recipient, or admin/staff may update
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.fromUserId == request.auth.uid)
                    || (isAuth() && resource.data.toUserId   == request.auth.uid);
      allow delete: if false;
    }

    match /viewings/{id} {
      // Agents and clients see only their own viewings; admin sees all
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid)
                    || (isAuth() && resource.data.agentId  == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      // Only the assigned agent or admin may update (check-in, photos, report)
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /services/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.requestedBy == request.auth.uid
                        || resource.data.assignedTo == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow delete: if false;
    }

    match /partners/{id} {
      // Financial details require authentication; public listing info is fine
      allow read:   if isAuth();
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    match /invoices/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.billedTo == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /expenses/{id} {
      allow read:   if isAdminOrStaff();
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /tasks/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.assignedTo == request.auth.uid);
      allow delete: if false;
    }

    match /attendance/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    match /leaves/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /payroll/{id} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /reviews/{id} {
      allow read:   if true;
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /branches/{id} {
      allow read:   if isAuth();
      allow create: if isAdminOrStaff() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /referrals/{id} {
      allow read:   if isAuth() && (resource.data.referrerId == request.auth.uid || isAdminOrStaff());
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /notifications/{id} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      // Users may only create notifications addressed to themselves (prevents notification spam)
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && hasStandardFields();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /messages/{id} {
      // Messages are private — only sender and recipient may read
      allow read:   if isAdminOrStaff()
                    || (isAuth() && (resource.data.senderId   == request.auth.uid
                        || resource.data.receiverId == request.auth.uid));
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff();
      allow delete: if false;
    }

    match /auditlogs/{id} {
      // Immutable — no updates or deletes ever
      allow read:   if isAdminOrStaff();
      allow create: if isAuth() && hasStandardFields();
      allow update: if false;
      allow delete: if false;
    }

    // ── SITE DEVELOPMENT MODULE ───────────────────────

    match /sites/{siteId} {
      allow read:   if true;
      allow create: if isAuth()
                    && request.auth.token.role in ['agent','Agent','developer','staff','admin','Admin','super_admin','ceo']
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && isRole('agent')
                        && resource.data.managingAgentId == request.auth.uid)
                    || (isAuth() && isRole('developer')
                        && resource.data.developerId == request.auth.uid);
      allow delete: if false;
    }

    match /plots/{plotId} {
      allow read:   if true;
      allow create: if isAuth()
                    && request.auth.token.role in ['agent','Agent','staff','admin','Admin','super_admin','ceo']
                    && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth()
                        && get(/databases/$(database)/documents/sites/$(resource.data.siteId))
                           .data.managingAgentId == request.auth.uid)
                    || (isAuth() && resource.data.clientId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','clientId','reservedAt','reservedUntil','updatedAt','updatedBy']));
      allow delete: if false;
    }

    match /site_enquiries/{enquiryId} {
      allow read:   if isAdminOrStaff()
                    || (isAuth() && resource.data.clientId == request.auth.uid)
                    || (isAuth() && resource.data.agentId  == request.auth.uid);
      allow create: if isAuth() && hasStandardFields();
      allow update: if isAdminOrStaff()
                    || (isAuth() && resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }
  }
}
